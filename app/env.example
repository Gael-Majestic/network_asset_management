# ==============================================================
# .ENV.EXAMPLE
# This file is committed to Git as a TEMPLATE only.
# Copy it: cp .env.example .env
# Then fill in the real values in .env
# NEVER commit your actual .env file.
# ==============================================================

# --- Application ---
APP_NAME="Network Asset API"
APP_VERSION="1.0.0"
DEBUG=True

# --- Database ---
# Format: postgresql+asyncpg://USERNAME:PASSWORD@HOST:PORT/DATABASE_NAME
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_password_here
POSTGRES_HOST=db          # "db" when running inside Docker, "localhost" when running locally
POSTGRES_PORT=5432
POSTGRES_DB=network_asset_db

# This full URL is built automatically from the values above in config.py
# You do not need to set this manually

# --- Security ---
# Generate a strong secret key by running this command in your terminal:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here_replace_this

# How long (in minutes) before a JWT token expires
ACCESS_TOKEN_EXPIRE_MINUTES=30
