# ==============================================================
# .GITIGNORE
# Everything listed here is invisible to Git.
# ==============================================================

# --- Secrets --- NEVER commit these ---
.env

# --- Python bytecode (auto-generated by Python, not your code) ---
__pycache__/
*.py[cod]
*.pyo
*.pyd

# --- Virtual environment ---
venv/
env/
.venv/

# --- Testing & coverage ---
.pytest_cache/
.coverage
htmlcov/

# --- VS Code ---
.vscode/

# --- macOS ---
.DS_Store

# --- Alembic (keep the folder, ignore nothing here — migrations are committed) ---
# alembic/versions/*.py  ← DO commit these, they are your migration history

# --- Docker ---
# docker-compose.override.yml  ← if you create local overrides